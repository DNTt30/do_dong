# ═══════════════════════════════════════════════════════════════════════════════
# Đồ Đồng Thủ Công Nam Định — Environment Variables
# Copy file này → .env.local và điền giá trị thực
#
# CẢNH BÁO SECURITY:
#   - Không commit .env.local lên Git
#   - Không expose SUPABASE_SERVICE_ROLE_KEY ra frontend
#   - Chỉ NEXT_PUBLIC_* mới được dùng trong browser code
# ═══════════════════════════════════════════════════════════════════════════════

# ── Supabase (REQUIRED) ──────────────────────────────────────────────────────
# Lấy từ: Supabase Dashboard → Settings → API

# Public URL của project Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Anon key (public, safe to expose to browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service role key (PRIVATE — server only, NEVER expose to browser)
# Dùng để set admin role cho user trong Supabase
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Site Configuration ───────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://dodongnamdinh.vn

# ── Google Analytics 4 ──────────────────────────────────────────────────────
# Lấy từ: analytics.google.com → Admin → Data Streams → Measurement ID
# Format: G-XXXXXXXXXX
NEXT_PUBLIC_GA_ID=

# ── Facebook Pixel ───────────────────────────────────────────────────────────
# Lấy từ: business.facebook.com → Events Manager → Your Pixel → Pixel ID
# Format: 17 chữ số
NEXT_PUBLIC_FB_PIXEL_ID=

# ── Google Search Console ────────────────────────────────────────────────────
# Meta tag verification code (không cần nếu verify bằng DNS)
NEXT_PUBLIC_GSC_VERIFICATION=

# ── Zalo OA (tùy chọn) ───────────────────────────────────────────────────────
# App ID từ Zalo Developer → Zalo OA API
# NEXT_PUBLIC_ZALO_OA_ID=

# ═══════════════════════════════════════════════════════════════════════════════
# CÁCH GRANT ADMIN ROLE CHO USER:
#
# Chạy SQL này trong Supabase Dashboard → SQL Editor:
#
#   UPDATE auth.users
#   SET raw_app_meta_data = raw_app_meta_data || '{"role": "admin"}'::jsonb
#   WHERE email = 'admin@yourdomain.com';
#
# Hoặc dùng Supabase Management API với service_role key.
# ═══════════════════════════════════════════════════════════════════════════════
